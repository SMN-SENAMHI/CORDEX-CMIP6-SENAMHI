&share
 wrf_core = 'ARW',
 max_dom = 1,
 start_date = '2021-01-01_00:00:00',
 end_date   = '2021-01-01_21:00:00',
 interval_seconds = 10800
/

&geogrid
 parent_id         =   1,
 parent_grid_ratio =   1,
 i_parent_start    =   1,
 j_parent_start    =   1,
 e_we              =  460,
 e_sn              =  390,
 geog_data_res = '30s',
 dx = 25000,
 dy = 25000,
 map_proj = 'mercator',
 ref_lat   = -19.79801,
 ref_lon   = -57.50568,
 truelat1  = -25.544,
 truelat2  = 0,
 stand_lon = -69.967,
 geog_data_path = '/scratch/DMA/SMN/WPS_GEOG/'
/

&ungrib
 out_format = 'WPS',
 prefix = 'FILE',
/

&metgrid
